                            <% if (settings.mobile) { %>
                            <li>
                                <i class="fa fa-phone"></i>
                                <span><%= settings.mobile %></span>
                            </li>
                            <% } %>

                            <% if (settings.us_mobile) { %>
                            <li>
                                <i class="fa fa-phone"></i>
