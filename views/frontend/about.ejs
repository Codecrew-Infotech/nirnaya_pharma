<!DOCTYPE html>
<html>
<%- include('partials/front_head'); %>

	<body class="royal_preloader">
		<div id="page" class="site">

			<!-- #site-header -->
			<%- include('partials/front_header'); %>
				<div id="content" class="site-content">
					<div class="page-header" style="background: url(/bg-pheader.jpg) no-repeat center center;">
						<div class="container">
							<div class="breadc-box no-line">
								<div class="row">
									<div class="col-md-6">
										<h1 class="page-title">About Us</h1>
									</div>
									<div class="col-md-6 mobile-left text-right">
										<ul id="breadcrumbs" class="breadcrumbs none-style">
											<li><a href="index.html">Home</a></li>
											<li class="active">About Us</li>
										</ul>
									</div>
								</div>
							</div>
						</div>
					</div>
					<div class="entry-content">
						<div class="container">
							<div class="boxed-content">
								<section class="wpb_row row-fluid section-padd">
									<div class="container">
										<div class="row">
											<div class="wpb_column column_container col-sm-12">
												<% if (aboutUs.sections && aboutUs.sections.length> 0) { %>
													<% const section=aboutUs.sections[0]; %>

														<div class="wpb_wrapper">
															<div class="section-head">
																<h6><span>
																		<%= section.subTitle %>
																	</span></h6>
																<h2 class="section-title">
																	<%= section.title %>
																</h2>
															</div>

															<div class="wpb_text_column wpb_content_element">
																<div class="wpb_wrapper">
																	<%- section.content %>
																</div>
															</div>
														</div>
														<% } %>

											</div>
											<div class="wpb_column column_container col-sm-12">
												<div class="column-inner">
													<div class="wpb_wrapper">
														<div
															class="row wpb_row inner row-fluid row-o-equal-height row-flex">
															<div class="radius-left custom-padd-2 wpb_column column_container col-sm-12 col-md-6 col-has-fill"
																style="background-image: url(/<%=aboutUs.ownerDetail.image%>);">
																<div class="column-inner">
																	<div class="wpb_wrapper"></div>
																</div>
															</div>
															<div
																class="bg-second radius-right wpb_column column_container col-sm-12 col-md-6">
																<div class="column-inner">
																	<div class="wpb_wrapper">
																		<div
																			class="wpb_text_column wpb_content_element text-light padding-box">
																			<div class="wpb_wrapper">
																				<%=aboutUs.ownerDetail.content%>

																			</div>
																		</div>

																		<div
																			class="wpb_text_column wpb_content_element text-light info-box padd-box">
																			<div class="wpb_wrapper">
																				<div class="sign">
																					<h5>
																						<%=aboutUs.ownerDetail.name%>
																					</h5>
																					<p>
																						<%=aboutUs.ownerDetail.educationInfo%>
																					</p>
																				</div>
																			</div>
																		</div>
																	</div>
																</div>
															</div>
														</div>
													</div>
												</div>
											</div>

											<div class="wpb_column column_container col-sm-12">
												<% if (aboutUs.sections && aboutUs.sections.length> 1) { %>
													<% aboutUs.sections.slice(1).forEach(section=> { %>

														<div class="wpb_wrapper" style="
    margin-top: 25px;
">
															<div class="section-head">
																<h6><span>
																		<%= section.subTitle %>
																	</span></h6>
																<h2 class="section-title">
																	<%= section.title %>
																</h2>
															</div>

															<div class="wpb_text_column wpb_content_element">
																<div class="wpb_wrapper">
																	<%- section.content %>
																</div>
															</div>
														</div>

														<% }) %>
															<% } %>

											</div>


										</div>
									</div>
								</section>

								<section class="wpb_row row-fluid section-padd">
						    <div class="container">
						        <div class="row">
						            <div class="wpb_column column_container col-sm-12">
						                <div class="column-inner">
						                    <div class="wpb_wrapper">
						                        <div class="section-head ">
						                            <h6><span>Support</span></h6>
						                            <h2 class="section-title">How can we help</h2>
						                        </div>

						                        <div class="empty_space_12"></div>
						                    </div>
						                </div>
						            </div>
						            <div class="wpb_column column_container col-sm-6 col-md-7">
						                <div class="column-inner">
						                    <div class="wpb_wrapper">
						                        <div class="wpcf7">
						                            <div class="screen-reader-response"></div>
						                            <form method="post" class="wpcf7-form">
						                                <div class="row">
						                                    <div class="col-md-6">
						                                    	<span class="wpcf7-form-control-wrap your-name">
							                                    	<input type="text" name="name" value="" size="40" class="wpcf7-form-control"  placeholder="Your Name">
																	<span class="field-error" id="err-name">Name is required.</span>
							                                    </span>
						                                    </div>
						                                    <div class="col-md-6">
						                                    	<span class="wpcf7-form-control-wrap your-email">
						                                    		<input type="email" name="email" value="" size="40" class="wpcf7-form-control"  placeholder="Email Address">
																	<span class="field-error" id="err-email">Email is required.</span>
						                                    	</span>
						                                    </div>
						                                </div>
						                                <div class="contact-mess">
						                                	<span class="wpcf7-form-control-wrap your-message">
						                                		<textarea name="message" cols="40" rows="10" class="wpcf7-form-control"  placeholder="Messenger"></textarea>
																<span class="field-error" id="err-message">Message is required.</span>
							                                </span>
							                            </div>
						                                <p>
						                                    <input type="submit" value="SUBMIT" class="wpcf7-form-control wpcf7-submit btn">
						                                </p>
						                            </form>
						                        </div>
						                        <div class="empty_space_30 lg-hidden md-hidden"></div>
						                    </div>
						                </div>
						            </div>
						            <div class="wpb_column column_container col-sm-6 col-md-5">
						                <div class="column-inner">
						                    <div class="wpb_wrapper">
						                        <div class="wpb_text_column wpb_content_element text-light contact-box">
						                            <div class="wpb_wrapper">
						                                <h6 class="font12">Hotline</h6>
						                                <h4><%= settings.mobile %></h4>
						                                <h6 class="font12">Location</h6>
						                                <h4 style="max-width: 75%;"><%= settings.indian_address %></h4>
						                                <p><a class="pagelink" href="/contact">Contact Us</a></p>

						                            </div>
						                        </div>
						                    </div>
						                </div>
						            </div>
						        </div>
						    </div>
						</section>



							</div>
						</div>
					</div>
				</div>

				<!-- #content -->
				<%- include('partials/front_footer'); %>

					<!-- #site-footer -->
		</div>

		<%- include('partials/front_javascript'); %>

	</body>

</html>