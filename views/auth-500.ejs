<%- contentFor('extra_css') %>

<%- contentFor('content') %>

<div class="container-xxl">
    <div class="row vh-100 d-flex justify-content-center align-items-center">
        <div class="col-lg-4 col-md-6">
            <div class="card shadow-sm">
                
                <!-- Header -->
                <div class="card-body bg-danger text-white text-center rounded-top py-4">
                    <a href="/" class="logo logo-admin d-block mb-2">
                        <img src="/images/logo-sm.png" height="45" alt="logo">
                    </a>
                    <h4 class="fw-semibold mb-1">Access Denied</h4>
                    <p class="mb-0 small">You don’t have permission to access this page.</p>
                </div>

                <!-- Body -->
                <div class="card-body text-center py-4">
                    <img src="/images/extra/error.svg" alt="403 error" height="140" class="mb-3">
                    
                    <h1 class="fw-bold text-danger">403</h1>
                    <h5 class="text-muted mb-3">Forbidden</h5>

                    <p class="text-muted mb-4">
                        Sorry, you are not authorized to view this resource.
                        Please contact your administrator if you believe this is a mistake.
                    </p>

                    <div class="d-grid gap-2">
                        <a href="/admin" class="btn btn-primary">
                            Back to Dashboard
                        </a>
                        <a href="/admin/logout" class="btn btn-outline-secondary">
                            Logout
                        </a>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

<%- contentFor('extra_javascript') %>